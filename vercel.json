{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/.well-known/farcaster.json",
      "has": [
        {
          "type": "host",
          "value": "celo-nft-phi.vercel.app"
        }
      ],
      "destination": "/.well-known/farcaster-old.json"
    },
    {
      "source": "/.well-known/farcaster.json",
      "destination": "/.well-known/farcaster-new.json"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/farcaster(-old|-new)?\\.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/(icon|splash|image).png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/notification",
      "schedule": "0 16 * * *"
    }
  ]
}
